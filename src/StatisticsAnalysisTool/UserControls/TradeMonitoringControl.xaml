<UserControl x:Class="StatisticsAnalysisTool.UserControls.TradeMonitoringControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:viewModels="clr-namespace:StatisticsAnalysisTool.ViewModels"
             xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
             xmlns:trade="clr-namespace:StatisticsAnalysisTool.Trade"
             mc:Ignorable="d" 
             d:DesignHeight="1950" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel}">
    <UserControl.Resources>
        <trade:TradeDataTemplateSelector x:Key="TradeDataTemplateSelector"
                                         MailMarketplaceBuyOrderExpiredTemplate="{StaticResource MailMarketplaceBuyOrderExpiredTemplate}"
                                         MailMarketplaceBuyOrderFinishedTemplate="{StaticResource MailMarketplaceBuyOrderFinishedTemplate}"
                                         MailMarketplaceSellOrderExpiredTemplate="{StaticResource MailMarketplaceSellOrderExpiredTemplate}"
                                         MailMarketplaceSellOrderFinishedTemplate="{StaticResource MailMarketplaceSellOrderFinishedTemplate}"
                                         InstantSellTemplate="{StaticResource InstantSellTemplate}" 
                                         InstantBuyTemplate="{StaticResource InstantBuyTemplate}"
                                         ManualSellTemplate="{StaticResource ManualSellTemplate}" 
                                         ManualBuyTemplate="{StaticResource ManualBuyTemplate}" 
                                         CraftingTemplate="{StaticResource CraftingTemplate}" />
    </UserControl.Resources>
    <Grid>
        <Grid VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="34"/>
                <RowDefinition Height="34"/>
                <RowDefinition Height="4"/>
            </Grid.RowDefinitions>

            <!-- Row 0 left: Filter icon + search + redo + spinner + Trade Type -->
            <StackPanel Grid.Row="0"
                        Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0">
                <fa5:ImageAwesome Icon="Solid_Filter"
                                  ToolTip="Filter"
                                  Foreground="{StaticResource SolidColorBrush.Text.1}"
                                  Width="16"
                                  Height="16"
                                  Margin="0,0,5,0"/>
                <Grid Width="200"
                      Height="24">
                    <TextBox x:Name="TradeSearchBox"
                             Text="{Binding TradeMonitoringBindings.TradesSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="SearchText_TextChanged"
                             Width="200"
                             Height="24"/>
                    <TextBlock IsHitTestVisible="False"
                               Text="Search trades..."
                               Margin="5,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource SolidColorBrush.Text.5}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility"
                                        Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=TradeSearchBox}"
                                                 Value="">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <fa5:ImageAwesome Icon="Solid_Redo"
                                  ToolTip="Reset filters"
                                  Foreground="{StaticResource SolidColorBrush.Text.1}"
                                  Width="16"
                                  Height="16"
                                  Margin="5,0"
                                  MouseUp="FilterReset_MouseUp"/>
                <fa5:ImageAwesome Visibility="{Binding TradeMonitoringBindings.FilteringIsRunningIconVisibility}"
                                  Width="16"
                                  Height="16"
                                  Margin="0,0,10,0"
                                  Style="{StaticResource LoadingIconStyle}"/>

                <!-- Trade Type moved next to search for small screens -->
                <ComboBox ItemsSource="{Binding TradeMonitoringBindings.TradeTypeFilterItems}"
                          Tag="{Binding TradeMonitoringBindings.TradeTypeSummary}"
                          Width="120"
                          Margin="8,0,5,0"
                          ToolTip="Trade Type">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding DisplayName}"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Click="FilterCheckBox_Click"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Row 0 right: Select/Deselect + Delete + info -->
            <StackPanel Grid.Row="0"
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Margin="0,0,5,0">
                <Button Content="{Binding Translation.SelectDeselectAll, FallbackValue=SELECT__DESELECT__ALL}"
                        Height="24"
                        Width="180"
                        MaxWidth="200"
                        MinWidth="150"
                        Margin="0,0,5,0"
                        Click="BtnSelectSwitchAllMails_Click"/>
                <Button Content="{Binding Translation.DeleteSelectedTrades, FallbackValue=DELETE__SELECTED__TRADES}"
                        Height="24"
                        Width="200"
                        MaxWidth="300"
                        MinWidth="180"
                        IsEnabled="{Binding TradeMonitoringBindings.IsDeleteTradesButtonEnabled}"
                        Click="BtnDeleteSelectedMails_Click"/>
                <Grid Height="20"
                      Width="20"
                      Margin="5,0,0,0"
                      VerticalAlignment="Center"
                      MouseEnter="OpenMailMonitoringPopup_MouseEnter"
                      MouseLeave="CloseMailMonitoringPopup_MouseLeave">
                    <fa5:ImageAwesome Icon="Solid_InfoCircle"
                                      Foreground="{StaticResource SolidColorBrush.Text.1}"/>
                </Grid>
            </StackPanel>

            <!-- Row 1: Category → Sub1 → Sub2 → Sub3 → Tier → Enchantment -->
            <StackPanel Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0">
                <ComboBox ItemsSource="{Binding TradeMonitoringBindings.CategoryItems}"
                          SelectedItem="{Binding TradeMonitoringBindings.SelectedCategory, Mode=TwoWay}"
                          Tag="{Binding TradeMonitoringBindings.CategorySummary}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          Width="140"
                          Margin="0,0,5,0"
                          ToolTip="Category"
                          SelectionChanged="TradeCategory_SelectionChanged"/>
                <ComboBox ItemsSource="{Binding TradeMonitoringBindings.SubCategory1Items}"
                          SelectedItem="{Binding TradeMonitoringBindings.SelectedSubCategory1, Mode=TwoWay}"
                          Tag="{Binding TradeMonitoringBindings.SubCategory1Summary}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          Width="120"
                          Margin="0,0,5,0"
                          ToolTip="Sub-Category"
                          SelectionChanged="TradeCategory_SelectionChanged"/>
                <ComboBox ItemsSource="{Binding TradeMonitoringBindings.SubCategory2Items}"
                          SelectedItem="{Binding TradeMonitoringBindings.SelectedSubCategory2, Mode=TwoWay}"
                          Tag="{Binding TradeMonitoringBindings.SubCategory2Summary}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          Width="120"
                          Margin="0,0,5,0"
                          ToolTip="Sub-Category 2"
                          SelectionChanged="TradeCategory_SelectionChanged"/>
                <ComboBox ItemsSource="{Binding TradeMonitoringBindings.SubCategory3Items}"
                          SelectedItem="{Binding TradeMonitoringBindings.SelectedSubCategory3, Mode=TwoWay}"
                          Tag="{Binding TradeMonitoringBindings.SubCategory3Summary}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          Width="120"
                          Margin="0,0,5,0"
                          ToolTip="Sub-Category 3"
                          SelectionChanged="TradeCategory_SelectionChanged"/>
                <ComboBox ItemsSource="{Binding TradeMonitoringBindings.TierFilterItems}"
                          Tag="{Binding TradeMonitoringBindings.TierSummary}"
                          Width="60"
                          Margin="0,0,5,0"
                          ToolTip="Tier">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding DisplayName}"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Click="FilterCheckBox_Click"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox ItemsSource="{Binding TradeMonitoringBindings.LevelFilterItems}"
                          Tag="{Binding TradeMonitoringBindings.LevelSummary}"
                          Width="70"
                          Margin="0,0,5,0"
                          ToolTip="Enchantment">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding DisplayName}"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Click="FilterCheckBox_Click"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Row 2: Date pickers below filters (keeps space for small screens) -->
            <StackPanel Grid.Row="2"
                        Grid.ColumnSpan="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="6,4,6,4">
                <DatePicker SelectedDate="{Binding TradeMonitoringBindings.DatePickerTradeFrom}"
                            SelectedDateChanged="DatePicker_OnSelectedDateChanged"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip="From date"/>
                <TextBlock Text="{Binding Translation.To, StringFormat='{}to ', FallbackValue=to }"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SolidColorBrush.Text.1}"
                           Margin="4,0"/>
                <DatePicker SelectedDate="{Binding TradeMonitoringBindings.DatePickerTradeTo}"
                            SelectedDateChanged="DatePicker_OnSelectedDateChanged"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip="To date"/>
            </StackPanel>

            <!-- Row 3: Separator -->
            <Separator Grid.Row="3"
                       Grid.ColumnSpan="3"
                       Background="{StaticResource SolidColorBrush.Background.2}"/>
        </Grid>
        <Grid Margin="0,110,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="{Binding TradeMonitoringBindings.GridSplitterPosition ,Mode=TwoWay, FallbackValue=*}"/>
            </Grid.RowDefinitions>

            <GridSplitter Grid.Row="1" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" HorizontalAlignment="Stretch" Margin="0,0,1,1" Background="{StaticResource SolidColorBrush.Accent.Blue.4}" />

            <Grid Row="0" Margin="0,5,0,6" Grid.RowSpan="2">
                <ScrollViewer>
                    <StackPanel Orientation="Vertical">
                        <ContentControl Margin="0,0,0,0" ContentTemplate="{StaticResource MailStatsObjectTemplate}" Content="{Binding TradeMonitoringBindings.TradeStatsObject}" />
                        <ContentControl Margin="0,0,0,0" ContentTemplate="{StaticResource MailOptionsObjectTemplate}" Content="{Binding TradeMonitoringBindings.TradeOptionsObject}" />
                        <ContentControl Margin="0,0,0,0" ContentTemplate="{StaticResource ManuallyMailMenuTemplate}" Content="{Binding TradeMonitoringBindings.ManuallyTradeMenuObject}" />
                        <ContentControl Margin="0,0,0,0" ContentTemplate="{StaticResource TradeExportTemplate}" Content="{Binding TradeMonitoringBindings.TradeExportTemplateObject}" />
                    </StackPanel>
                </ScrollViewer>
                <StackPanel Orientation="Horizontal" Height="28" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                    <TextBlock Margin="0,0,10,0" Foreground="{StaticResource SolidColorBrush.Text.3}" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} / {1}" FallbackValue="0 / 0">
                                <Binding Path="TradeMonitoringBindings.CurrentTradeCounts" IsAsync="True" Mode="OneWay" />
                                <Binding Path="TradeMonitoringBindings.TotalTradeCounts" IsAsync="True" Mode="OneWay" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <Grid Height="16" Width="16" Margin="0,0,27,0" VerticalAlignment="Center">
                        <fa5:ImageAwesome Icon="Solid_ListAlt" Foreground="{StaticResource SolidColorBrush.Text.3}" />
                    </Grid>
                </StackPanel>
            </Grid>

            <Grid Row="2">
                <vwp:VirtualizingItemsControl ItemsSource="{Binding TradeMonitoringBindings.TradeCollectionView, IsAsync=True, Mode=OneWay}"
                                              ItemTemplateSelector="{StaticResource TradeDataTemplateSelector}"
                                              VirtualizingPanel.CacheLengthUnit="Item"
                                              VirtualizingPanel.CacheLength="10,10"
                                              VirtualizingPanel.ScrollUnit="Pixel"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Visible" />
            </Grid>
        </Grid>

        <Grid Visibility="{Binding TradeMonitoringBindings.IsTradeMonitoringPopupVisible, FallbackValue=Hidden}" 
              Margin="0,35,0,0" Background="{StaticResource SolidColorBrush.Background.2}">
            <StackPanel CanHorizontallyScroll="False" CanVerticallyScroll="True" Margin="10,0">
                <DockPanel Margin="0,0,0,16">
                    <Grid Height="16" Width="16" Margin="0,3,10,0" VerticalAlignment="Top">
                        <fa5:ImageAwesome Icon="Regular_DotCircle" Foreground="{StaticResource SolidColorBrush.Accent.Blue.3}" />
                    </Grid>
                    <TextBlock Text="{Binding Translation.TradeMonitoringDescription1}" Foreground="{StaticResource SolidColorBrush.Text.1}" 
                               FontSize="16" TextWrapping="Wrap" Width="auto" />
                </DockPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
