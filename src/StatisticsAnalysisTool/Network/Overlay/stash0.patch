+                                                    payload: data,
+                                                });
+                                            } catch (e) {
+                                                console.debug(
+                                                    "acquireVsCodeApi().postMessage failed",
+                                                    e
+                                                );
+                                            }
+                                        }
+                                    } catch (e) {}
+                                    try {
+                                        // Parent frames (generic embedding)
+                                        if (
+                                            window.parent &&
+                                            window.parent !== window &&
+                                            typeof window.parent.postMessage ===
+                                                "function"
