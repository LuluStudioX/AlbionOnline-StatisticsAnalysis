+                            JSON.stringify(DEFAULT_OVERLAY_SETTINGS)
+                        );
+                    }
+                    // Update overlaySettings with received values
+                    if (typeof s.fontSize === "number")
+                        overlaySettings.fontSize = s.fontSize;
+                    if (typeof s.iconSize === "number")
+                        overlaySettings.iconSize = s.iconSize;
+                    if (typeof s.titleFontSize === "number")
+                        overlaySettings.titleFontSize = s.titleFontSize;
+                    if (typeof s.totalFontSize === "number")
+                        overlaySettings.totalFontSize = s.totalFontSize;
+                    if (typeof s.perHourFontSize === "number")
+                        overlaySettings.perHourFontSize = s.perHourFontSize;
+                    if (typeof s.autoHideZero === "boolean")
+                        overlaySettings.autoHideZero = s.autoHideZero;
+                    if (typeof s.metricSettings === "object")
+                        overlaySettings.metricSettings = s.metricSettings;
+
+                    // Apply theme immediately so UI/look updates even if no metrics yet
+                    if (s.theme) {
+                        setOverlayTheme(s.theme);
+                    } else {
+                        // Re-apply current theme to ensure styling consistency
