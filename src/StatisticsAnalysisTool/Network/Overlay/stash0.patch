+                    // Only re-render metric DOM when either we've already received
+                    // real metric data, or the settings explicitly request showing
+                    // zero values (autoHideZero === false). This prevents settings
+                    // updates from forcing an empty dashboard to display zeros.
+                    var shouldRenderNow =
+                        !!window._overlayHasReceivedData ||
+                        overlaySettings.autoHideZero === false;
+                    if (shouldRenderNow) {
+                        renderMetricsRow();
+                    }
+
+                    showToast("Settings applied!");
+                } catch (err) {
+                    console.error("Failed to handle settings message:", err);
+                    // Fallback for pipe-delimited stat payloads
+                    if (typeof json === "string" && json.indexOf("|") > 0) {
+                        lastStatsPayload = json;
+                        handleStatsDelimited(json);
+                    }
+                }
+            }
+            // Connection status UI removed. This function intentionally left blank to avoid runtime errors
+            function setConnectionStatus(status, color) {
+                // no-op
+            }
+            // Initialize overlay client using shared overlay-common.js
+            (function () {
+                var s = document.createElement("script");
+                s.src = "/Network/Overlay/overlay-common.js";
+                s.onload = function () {
