+                        }
+
+                        var client = initOverlayClient("dashboard", {
+                            onStats: function (data) {
+                                try {
+                                    // Keep a copy for debugging
+                                    lastStatsPayload = data;
+
+                                    // Update debug counters and indicator
+                                    window._overlayUpdateCount =
+                                        (window._overlayUpdateCount || 0) + 1;
+                                    window._overlayLastReceived = Date.now();
+                                    try {
+                                        var dbgEl = document.getElementById(
+                                            "overlay-debug-indicator"
+                                        );
+                                        if (!dbgEl) {
+                                            dbgEl =
+                                                document.createElement("div");
+                                            dbgEl.id =
+                                                "overlay-debug-indicator";
+                                            dbgEl.style.position = "fixed";
+                                            dbgEl.style.right = "8px";
