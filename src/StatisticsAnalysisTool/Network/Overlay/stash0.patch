+                                            dbgEl.style.padding = "6px 8px";
+                                            dbgEl.style.background =
+                                                "rgba(0,0,0,0.6)";
+                                            dbgEl.style.color = "#fff";
+                                            dbgEl.style.fontSize = "12px";
+                                            dbgEl.style.borderRadius = "6px";
+                                            dbgEl.style.zIndex = 10000;
+                                            dbgEl.style.display = "none";
+                                            document.body.appendChild(dbgEl);
+                                        }
