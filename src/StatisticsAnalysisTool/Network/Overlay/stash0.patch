index 00000000..97be9828
--- /dev/null
+++ b/src/StatisticsAnalysisTool/Network/Overlay/damage.html
@@ -0,0 +1,427 @@
+<!DOCTYPE html>
+<html lang="en">
+    <head>
+        <meta charset="UTF-8" />
+        <title>Damage Overlay</title>
+        <!-- Use shared overlay CSS so damage and dashboard share theme -->
+        <link rel="stylesheet" href="/Network/Overlay/overlay-common.css" />
+        <script src="/Network/Overlay/overlay-common.js"></script>
+    </head>
+    <body>
+        <div id="damage" class="damage-list"></div>
+        <script>
+            // Minimal query param parsing for preview transparency
+            function getQuery() {
+                var q = {};
+                try {
+                    var sp = new URLSearchParams(location.search);
+                    for (var pair of sp.entries()) q[pair[0]] = pair[1];
+                } catch (e) {}
+                return q;
+            }
+            var qp = getQuery();
+
+            function applyInitialBackgroundForPreview(theme) {
+                try {
+                    if (qp.transparent === "1") {
+                        document.body.style.background = "transparent";
+                    } else {
+                        if (theme === "Light" || theme === "White")
+                            document.body.style.background = "#fff";
+                        else
+                            document.body.style.background = "rgba(0,0,0,0.85)";
+                    }
+                } catch (e) {}
+            }
+            function formatK(v) {
+                var n = Number(v);
+                if (!isFinite(n) || isNaN(n)) return "0";
+                var abs = Math.abs(n);
+                if (abs >= 1000000) {
+                    return (abs / 1000000).toFixed(1).replace(/\.0$/, "") + "M";
+                }
+                if (abs >= 1000) {
+                    return (abs / 1000).toFixed(1).replace(/\.0$/, "") + "K";
+                }
+                return Math.round(n).toLocaleString();
+            }
+            function render(list) {
+                var cont = document.getElementById("damage");
+                cont.innerHTML = "";
+                if (!Array.isArray(list) || list.length === 0) {
+                    // show placeholder when no damage is available
+                    var p = document.createElement("div");
+                    p.className = "center";
+                    // color handled by shared CSS (.center -> color: var(--muted))
+                    p.textContent = "Waiting for metrics";
+                    cont.appendChild(p);
+                    return;
+                }
+                list.forEach(function (item) {
+                    // If overlay settings request hiding the local player, filter by username if provided
+                    try {
+                        if (
+                            overlaySettings &&
+                            overlaySettings.hideSelf &&
+                            overlaySettings.username
+                        ) {
+                            var uname = String(
+                                overlaySettings.username || ""
+                            ).trim();
+                            var itemName = String(item.name || "").trim();
+                            if (
+                                uname !== "" &&
+                                itemName !== "" &&
+                                uname.toLowerCase() === itemName.toLowerCase()
+                            ) {
+                                // skip rendering this entry
+                                return;
+                            }
+                        }
+                    } catch (e) {}
+                    var d = document.createElement("div");
+                    d.className = "damage-item";
+                    // Name first
+                    var name = document.createElement("div");
+                    name.className = "damage-name";
+                    name.textContent = item.name || "unknown";
+                    d.appendChild(name);
